<?xml version="1.0" encoding="utf-8"?>
<!-- Debug-only adaptive icon: red background + the stock foreground. main/ has
     no anydpi-v26 icon, so on API 26+ this overrides the PNG launcher for the
     debug build only; release keeps the normal icon. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/debug_icon_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
