{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voxtide",
  "version": "0.1.0",
  "identifier": "com.voxtide.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Voxtide",
        "width": 1200, "height": 780,
        "minWidth": 480, "minHeight": 400,
        "resizable": true, "decorations": true, "transparent": false,
        "visible": true, "url": "index.html"
      },
      {
        "label": "overlay",
        "title": "Voxtide overlay",
        "width": 600, "height": 190,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false,
        "visible": false,
        "url": "overlay.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Real-time speech translation",
    "longDescription": "Voxtide captures live audio from your microphone or system output and renders real-time speech translation via Soniox.",
    "publisher": "Nam Ho",
    "homepage": "https://github.com/hophuongnam/Voxtide",
    "copyright": "Copyright © 2026 Nam Ho",
    "macOS": {
      "minimumSystemVersion": "13.0",
      "exceptionDomain": "stt-rt.soniox.com"
    },
    "windows": {
      "wix": { "language": "en-US" }
    }
  }
}
